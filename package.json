{
    "name": "realms-desktop",
    "version": "1.0.0",
    "description": "Realms WebClient Desktop App",
    "main": "out/main/index.js",
    "private": true,
    "author": {
        "name": "Realms",
        "email": "dev@realms.tv"
    },
    "homepage": "https://realms.tv",
    "build": {
        "appId": "tv.realms.web",
        "productName": "Realms",
        "afterPack": "./scripts/after-pack.mjs",
        "compression": "normal",
        "directories": {
            "output": "out"
        },
        "files": [
            "out/main/**/*",
            "out/preload/**/*",
            "out/renderer/**/*",
            "!out/**/*.map",
            "static/**/*",
            "node_modules/ffmpeg-static/ffmpeg.exe",
            "node_modules/ffmpeg-static/index.js",
            "node_modules/ffmpeg-static/package.json"
        ],
        "asarUnpack": [
            "node_modules/ffmpeg-static/ffmpeg.exe"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "static/icons/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "installerSidebar": "assets/installer-banner-resized.bmp",
            "uninstallerSidebar": "assets/installer-banner-resized.bmp"
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "zip",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "icon": "static/icons/icon.icns"
        },
        "linux": {
            "target": [
                {
                    "target": "AppImage",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "deb",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "maintainer": "Realms <dev@realms.tv>",
            "category": "Network",
            "icon": "static/icons/icon.png",
            "executableName": "realms"
        },
        "deb": {
            "afterInstall": null,
            "afterRemove": null,
            "depends": [
                "libnotify4",
                "libxtst6",
                "libnss3"
            ]
        }
    },
    "scripts": {
        "build:local": "cross-env ELECTRON_ENV=local   electron-vite build",
        "build:school": "cross-env ELECTRON_ENV=school  electron-vite build",
        "build:staging": "cross-env ELECTRON_ENV=staging electron-vite build",
        "build:realms": "cross-env ELECTRON_ENV=realms  electron-vite build",
        "dev": "cross-env ELECTRON_ENV=local   electron-vite dev",
        "start:school": "npm run build:school  && electron out/main/index.js",
        "start:staging": "npm run build:staging && electron out/main/index.js",
        "start:realms": "npm run build:realms  && electron out/main/index.js",
        "dist:school": "npm run build:school  && electron-builder --win",
        "dist:staging": "npm run build:staging && electron-builder --win",
        "dist:realms": "npm run build:realms  && electron-builder --win",
        "dist:school:linux": "npm run build:school  && electron-builder --linux",
        "dist:staging:linux": "npm run build:staging && electron-builder --linux",
        "dist:realms:linux": "npm run build:realms  && electron-builder --linux",
        "generate:icons": "node scripts/generate-icons.mjs",
        "typecheck": "electron-vite typecheck",
        "lint": "eslint src",
        "format": "prettier --write \"src/**/*.{ts,tsx}\" \"src/renderer/**/*.html\""
    },
    "dependencies": {
        "ffmpeg-static": "^5.2.0"
    },
    "devDependencies": {
        "@electron/fuses": "^2.1.3",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/material": "^9.1.1",
        "@types/node": "^25.9.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^4.7.0",
        "cross-env": "^7.0.3",
        "electron": "^42.6.1",
        "electron-builder": "^26.15.3",
        "electron-vite": "^5.0.0",
        "esbuild": "^0.28.1",
        "eslint": "^9.39.4",
        "i18next": "^26.3.6",
        "prettier": "^3.9.4",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-i18next": "^17.0.9",
        "sharp": "^0.35.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.63.0",
        "vite": "^6.4.3"
    },
    "overrides": {
        "glob": "^13.0.0",
        "rimraf": "^6.0.0",
        "uuid": "^11.0.0"
    }
}