{
    "compilerOptions": {
        "composite": true,
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": [
            "electron-vite/node"
        ]
    },
    "include": [
        "src/main/**/*",
        "src/preload/**/*",
        "src/shared/**/*",
        "electron.vite.config.ts"
    ]
}